          "updatedAt": 1783971504483,
          "position": 7
        },
        {
          "id": "41426a66-4048-4883-ab23-362fae0ff6fb",
          "term": "Finite Set",
          "kind": "standard",
          "definition": "A set with countable elements.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 8
        },
        {
          "id": "6e0ce588-75c9-46f3-bc38-98bed26aab8a",
          "term": "Infinite Set",
          "kind": "standard",
          "definition": "A set with uncountable elements.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 9
        },
        {
          "id": "f24a23eb-5fe4-4e60-bab3-b48abb73b52c",
          "term": "4 Relations of Two or More Sets",
          "kind": "enumeration",
          "definition": "",
          "answers": [
            "Equal Sets",
            "Equivalent Sets",
            "Joint Sets",
            "Disjoint Sets"
          ],
          "updatedAt": 1783971504483,
          "position": 10
        },
        {
          "id": "0f58088e-2035-4320-9eee-15711135e3a9",
          "term": "Equal Sets",
          "kind": "standard",
          "definition": "Sets that have the same elements.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 11
        },
        {
          "id": "26c5410f-223f-4939-9d19-f560f30b519c",
          "term": "Equivalent Sets",
          "kind": "standard",
          "definition": "Sets that have the same number of elements.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 12
        },
        {
          "id": "b3bf1cf4-1e14-400a-aab6-eef1a14d7d13",
          "term": "Joint Sets",
          "kind": "standard",
          "definition": "Sets that have at least one common element.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 13
        },
        {
          "id": "723f2398-232c-424b-bebe-935a3cd141e4",
          "term": "Disjoint Sets",
          "kind": "standard",
          "definition": "Sets that have no common element.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 14
        },
        {
          "id": "799b5c61-6f83-46e7-b4ca-81a636fc2971",
          "term": "Subset",
          "kind": "standard",
          "definition": "A set every element of which can be found on a bigger set.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 15
        },
        {
          "id": "6322d1e4-52bc-462f-8007-eed773f0bf11",
          "term": "Improper Subset",
          "kind": "standard",
          "definition": "A subset in which the first set is equal to the second set.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 16
        },
        {
          "id": "ac928126-800e-4fcf-9370-3bf87c2e3f58",
          "term": "Proper Subset",
          "kind": "standard",
          "definition": "A subset in which the first set is not equal to the second set.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 17
        },
        {
          "id": "4ccaf9ed-12e6-4b17-b7da-f5a9228da9d9",
          "term": "Power Set",
          "kind": "standard",
          "definition": "Used to know the number of subsets; equal to 2^n, where n is the number of elements.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 18
        },
        {
          "id": "a8159058-ef9a-478a-97b9-47091baf58de",
          "term": "4 Operations Performed on Sets",
          "kind": "enumeration",
          "definition": "",
          "answers": [
            "Union",
            "Intersection",
            "Difference",
            "Complement"
          ],
          "updatedAt": 1783971504483,
          "position": 19
        },
        {
          "id": "ca6f8fab-9f5c-4062-b61b-617d78eb1ac1",
          "term": "Union",
          "kind": "standard",
          "definition": "The operation whose elements are found in set A or set B or in both.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 20
        },
        {
          "id": "8a58bf5f-0175-4256-bc39-1355053c5f21",
          "term": "Intersection",
          "kind": "standard",
          "definition": "The operation whose elements are found in set A and set B.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 21
        },
        {
          "id": "414e5550-4ece-4905-8cf9-4a0e78144fc0",
          "term": "Difference",
          "kind": "standard",
          "definition": "The operation whose elements are found in A but not in set B.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 22
        },
        {
          "id": "b9aaaa81-f0b9-4ae1-a15a-5feb1b97f6ab",
          "term": "Complement",
          "kind": "standard",
          "definition": "The operation whose elements are found in the universal set but not in set A.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 23
        }
      ]
    }
