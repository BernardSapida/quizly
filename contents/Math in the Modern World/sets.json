        },
        {
          "id": "7cb2f4b8-9647-441c-9f32-1b1a1be9c586",
          "term": "3 Ways to Describe a Set",
          "kind": "enumeration",
          "definition": "",
          "answers": [
            "Verbal Description Method",
            "Roster Method",
            "Rule Method"
          ],
          "updatedAt": 1783971504483,
          "position": 1
        },
        {
          "id": "da8b787a-0a1e-47d6-af71-a2d2eae75ab6",
          "term": "Verbal Description Method",
          "kind": "standard",
          "definition": "A method of describing sets in the form of a sentence.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 2
        },
        {
          "id": "25a77bc6-55a5-4672-9d09-d061b41b88e2",
          "term": "Roster Method",
          "kind": "standard",
          "definition": "A method in which the elements of the given set are listed or enumerated, separated by commas, inside a pair of braces.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 3
        },
        {
          "id": "8ca3d12b-dc6a-4e6e-9e03-7b97dfae8d7e",
          "term": "Rule Method",
          "kind": "standard",
          "definition": "A method in which the common characteristic of the elements is defined, using the form {x/x...}.",
          "answers": null,
          "updatedAt": 1783971504483,
          "position": 4
        },
        {
