# Dev: use your local network IP, not localhost (physical devices can't resolve localhost)
EXPO_PUBLIC_API_URL=http://192.168.0.101:3000

# Prod:
# EXPO_PUBLIC_API_URL=https://yourdomain.com

# Pusher Channels (or Ably/Soketi as drop-in replacements)
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=ap1
